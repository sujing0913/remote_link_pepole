.container {
  padding: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.role-tabs {
  display: flex;
  background: #f6f7f9;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
}

.tab.active {
  background: #07c160;
  color: #fff;
  font-weight: 600;
}

.panel {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 20rpx;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.code-box {
  background: #0b1220;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin: 16rpx 0 24rpx;
  text-align: center;
}

.code {
  color: #fff;
  font-size: 56rpx;
  letter-spacing: 10rpx;
  font-weight: 700;
}

.row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.label {
  color: #666;
  font-size: 26rpx;
}

.value {
  color: #111;
  font-size: 26rpx;
  max-width: 520rpx;
  text-align: right;
  word-break: break-all;
}

.inline {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
}

.mini-btn {
  padding: 0 18rpx;
  line-height: 1.8;
}

.child-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.child-main {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  max-width: 520rpx;
}

.child-name {
  font-size: 28rpx;
  font-weight: 600;
}

.child-meta {
  font-size: 22rpx;
  color: #666;
}

.danger-btn {
  background: #ff4d4f;
  color: #fff;
}

.empty {
  color: #999;
  padding: 10rpx 0;
}

.input {
  border: 2rpx solid #e5e6eb;
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  font-size: 32rpx;
  margin: 16rpx 0 20rpx;
}

.primary-btn {
  background: #07c160;
  color: #fff;
}

.primary-btn[disabled] {
  opacity: 0.5;
}

.tips {
  margin-top: 20rpx;
  color: #666;
  font-size: 26rpx;
  line-height: 1.8;
}

.tip {
  margin-top: 8rpx;
}
