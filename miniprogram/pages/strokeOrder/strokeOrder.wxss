/* 笔顺查询小工具样式 */

.stroke-order-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 20rpx;
}

/* 页面标题 */
.page-header {
  text-align: center;
  padding: 30rpx 0;
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  text-shadow: 1rpx 1rpx 4rpx rgba(0, 0, 0, 0.1);
}

/* 查询区域 */
.search-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.search-input-wrapper {
  background: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  padding: 0 16rpx;
}

.search-btn-wrapper {
  display: flex;
  justify-content: center;
}

.search-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 16rpx;
  border: none;
}

.search-btn::after {
  border: none;
}

/* 查询结果展示 */
.result-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.result-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.character-box {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #e0eafc 0%, #cfdef3 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.character {
  font-size: 120rpx;
  font-weight: bold;
  color: #333;
}

.char-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.pinyin-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.pinyin {
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
  margin-right: 16rpx;
}

.audio-icon {
  font-size: 40rpx;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  margin-right: 8rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 笔顺动画区域 */
.stroke-animation-box {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 300rpx;
  position: relative;
}

.debug-url {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 10rpx;
  word-break: break-all;
}

.stroke-gif {
  width: 100%;
  height: 600rpx;
  object-fit: contain;
  display: block;
}

.loading-stroke {
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 历史查询列表 */
.history-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.history-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.filter-wrapper {
  display: flex;
  gap: 16rpx;
}

.filter-picker {
  flex-shrink: 0;
}

.filter-btn {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
}

.filter-text {
  font-size: 26rpx;
  color: #666;
  margin-right: 8rpx;
}

.filter-arrow {
  font-size: 20rpx;
  color: #999;
}

/* 历史记录列表 */
.history-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.history-item {
  display: flex;
  align-items: center;
  background: #f9f9f9;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.item-character {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #e0eafc 0%, #cfdef3 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.char-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
}

.item-pinyin {
  width: 120rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.pinyin-text {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
}

.item-pinyin .audio-icon {
  font-size: 32rpx;
  cursor: pointer;
  opacity: 0.7;
  transition: opacity 0.2s;
}

.item-pinyin .audio-icon:active {
  opacity: 1;
}

.item-stroke-preview {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.stroke-preview {
  max-width: 100%;
  max-height: 100%;
}

.item-date {
  flex-shrink: 0;
}

.date-text {
  font-size: 24rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
