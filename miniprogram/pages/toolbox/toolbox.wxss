/* 工具箱容器 */
.toolbox-container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f8f8f8;
}

/* 页面标题 */
.page-header {
  padding: 30rpx 0;
  text-align: center;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

/* 工具网格 */
.tools-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 20rpx 0;
}

/* 工具卡片 */
.tool-card {
  width: calc(50% - 10rpx);
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.tool-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.tool-placeholder {
  opacity: 0.6;
}

/* 工具图标 */
.tool-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

/* 工具名称 */
.tool-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

/* 工具描述 */
.tool-desc {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}
