<view class="container">
  <!-- 顶部查询区域 -->
  <view class="header">
    <!-- 第一行：今日打卡状态 + 监管人/打卡人信息 -->
    <view class="first-row">
      <!-- 今日打卡区块 -->
      <view class="info-block today-block">
        <text>
          <text class="label">今日打卡：</text>
          <text class="value {{isTodayDone ? 'done' : 'pending'}}">{{subjects[selectedSubjectIndex]}}-{{isTodayDone ? '已打卡' : '未打卡'}}</text>
        </text>
      </view>
      
      <!-- 分隔符 -->
      <view class="separator">|</view>
      
      <!-- 参与人选择下拉框和退出按钮 -->
      <view class="info-block participant-block">
        <text>参与人：</text>
        <picker mode="selector" range="{{participantList}}" range-key="nickName" value="{{selectedParticipantIndex}}" bindchange="onParticipantChange">
          <view class="picker">{{selectedParticipantIndex < participantList.length ? participantList[selectedParticipantIndex].nickName : '选择参与人'}}</view>
        </picker>
        <button wx:if="{{participantList.length > 0 && currentParticipantOpenId !== currentUserOpenId}}" class="exit-btn" bindtap="requestExit">申请退出</button>
      </view>
    </view>

  <!-- 第二行：日期星期 + 身份信息 + 历史记录 -->
    <view class="second-row">
      <view class="date-info">
        <text>{{currentDateStr}}</text>
      </view>
      <view class="user-role">
        <text>{{currentUserNickName}} ({{currentUserRole === 'organizer' ? '组织者' : '参与人'}})</text>
        <view class="logout-tag" bindtap="onLogout">退出</view>
      </view>
      <view class="history-link" bindtap="goToHistory">历史打卡记录 ></view>
    </view>

    <!-- 第三行：组织人信息（仅对参与人显示） -->
    <view wx:if="{{currentUserRole !== 'organizer'}}" class="third-row">
      <view class="supervisor-info">
        <text>组织人：{{supervisorNickName || '未知'}}</text>
      </view>
    </view>
  </view>

  <!-- 分隔线 -->
  <view class="divider"></view>

  <!-- 科目选择 -->
  <view class="subject-section">
    <text>科目：</text>
    <picker mode="selector" range="{{subjects}}" value="{{selectedSubjectIndex}}" bindchange="onSubjectChange">
      <view class="picker">{{subjects[selectedSubjectIndex]}}</view>
    </picker>
  </view>

  <!-- 主打卡按钮 -->
  <view class="main-section">
    <view class="punch-btn-container">
      <button class="punch-btn" bindtap="onPunch">
        <text>打卡</text>
      </button>
    </view>
  </view>
</view>
