.container {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background-color: #f8f8f8;
}

.header {
  width: 100%;
  background-color: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  margin-bottom: 50rpx;
}

.first-row-v2 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 20rpx;
}

.user-team-info-inline {
  display: flex;
  gap: 20rpx;
}

.user-team-info-inline .info-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
}

.user-team-info-inline .label {
  color: #666;
}

.user-team-info-inline .value.link {
  color: #007aff;
  text-decoration: underline;
  margin-left: 6rpx;
  max-width: 150rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-link {
  font-size: 24rpx;
  color: #576b95;
  white-space: nowrap;
}

.second-row-v2 {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.info-block {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}

.separator {
  margin: 0 16rpx;
  color: #ccc;
  font-size: 24rpx;
}

.third-row-v2 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.date-info {
  font-size: 24rpx;
  color: #999;
}

.invite-btn-small {
  background-color: #07c160;
  color: white;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
  min-width: 110rpx !important;
  width: auto !important;
  margin: 0 !important;
  line-height: 1.4;
  font-weight: normal;
}

.divider {
  width: 100%;
  height: 2rpx;
  background-color: #eee;
  margin: 40rpx 0;
}

.subject-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 50rpx;
}

.subject-section text {
  margin-right: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.picker {
  padding: 10rpx 20rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
  font-size: 26rpx;
  min-width: 180rpx;
  text-align: center;
}

.value {
  font-weight: bold;
}

.value.done {
  color: #07c160;
}

.value.pending {
  color: #fa5151;
}

.main-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.punch-btn-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.punch-btn {
  width: 360rpx !important;
  height: 360rpx !important;
  border-radius: 50%;
  background-color: #07c160;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 40rpx rgba(7, 193, 96, 0.3);
  padding: 0;
  margin-bottom: 60rpx;
}

.punch-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.modal-content {
  width: 80%;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-header {
  padding: 30rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  border-bottom: 1rpx solid #eee;
}

.modal-body {
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar-wrapper {
  padding: 0;
  width: 120rpx !important;
  height: 120rpx !important;
  border-radius: 50%;
  margin-bottom: 10rpx;
  overflow: hidden;
}

.avatar-tip {
  font-size: 22rpx;
  color: #999;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.input-group {
  width: 100%;
  margin-bottom: 30rpx;
}

.input-group .label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.modal-input {
  width: 100%;
  border: 1rpx solid #ddd;
  padding: 15rpx 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #eee;
}

.modal-footer button {
  flex: 1;
  border-radius: 0;
  font-size: 30rpx;
  padding: 20rpx 0;
  background: white;
  margin: 0;
  line-height: 1.5;
}

.modal-footer button::after {
  border: none;
}

.modal-footer .confirm-btn {
  color: #07c160;
  border-left: 1rpx solid #eee;
}

.modal-footer .cancel-btn {
  color: #999;
}
