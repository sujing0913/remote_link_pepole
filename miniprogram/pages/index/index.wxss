.container {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background-color: #f8f8f8;
}

.header {
  width: 100%;
  background-color: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  margin-bottom: 50rpx;
}

/* 第一行 */
.first-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.info-block {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}

.separator {
  margin: 0 16rpx;
  color: #ccc;
  font-size: 24rpx;
}

.today-block .label {
  margin-right: 10rpx;
}

.today-punch .label {
  margin-right: 10rpx;
}

/* 第二行 */
.second-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.date-info {
  font-size: 28rpx;
  color: #666;
}

.user-role {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #333;
}

/* 第三行：组织者信息 */
.third-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.supervisor-info {
  font-size: 24rpx;
  color: #666;
}

.history-link {
  font-size: 26rpx;
  color: #576b95;
}

.divider {
  width: 100%;
  height: 2rpx;
  background-color: #eee;
  margin: 40rpx 0;
}

.subject-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 50rpx;
}

.subject-section text {
  margin-right: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.picker {
  padding: 10rpx 20rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
  font-size: 26rpx;
  min-width: 180rpx;
  text-align: center;
}

.value {
  font-weight: bold;
}

.value.done {
  color: #07c160;
}

.value.pending {
  color: #fa5151;
}

.main-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.punch-btn-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.punch-btn {
  width: 360rpx !important;
  height: 360rpx !important;
  border-radius: 50%;
  background-color: #07c160;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 40rpx rgba(7, 193, 96, 0.3);
  padding: 0;
  margin-bottom: 60rpx;
}

.punch-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.invite-btn {
  width: 360rpx !important;
  height: 90rpx !important;
  background-color: #fff;
  color: #07c160;
  border: 2rpx solid #07c160;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.invite-btn:active {
  opacity: 0.7;
}
