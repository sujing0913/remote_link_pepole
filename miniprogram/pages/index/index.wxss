  max-height: 60vh;
}

.check-result-close-btn {
  margin: 20rpx 30rpx 30rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.check-result-close-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 英语单词列表样式 */
.word-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 15rpx;
}

.word-item {
  display: flex;
  align-items: center;
  padding: 15rpx 20rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  border-left: 4rpx solid #ddd;
}

.word-item .word-cn {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  min-width: 80rpx;
}

.word-item .word-arrow {
  font-size: 24rpx;
  color: #999;
  margin: 0 10rpx;
}

.word-item .word-en {
  font-size: 28rpx;
  font-weight: bold;
  flex: 1;
}

.word-item .word-en.correct {
  color: #52c41a;
}

.word-item .word-en.wrong {
  color: #ff4d4f;
  text-decoration: line-through;
}

.word-item .word-status {
  font-size: 24rpx;
  color: #999;
  margin-left: 10rpx;
}

.word-item.correct {
  border-left-color: #52c41a;
  background-color: #f6ffed;
}

.word-item.wrong {
  border-left-color: #ff4d4f;
  background-color: #fff2f0;
}
