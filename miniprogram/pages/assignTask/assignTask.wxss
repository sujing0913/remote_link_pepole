/* 容器样式 */
.assign-container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

/* 顶部标题 */
.header {
  background-color: #fff;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
  border-radius: 15rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
  display: block;
}

/* 分区卡片 */
.section-card {
  background-color: #fff;
  padding: 0;
  border-radius: 15rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

/* 三个模块的不同背景色 */
/* 筛选条件模块 - 蓝色系 */
.section-card.filter-section {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
}

.section-card.filter-section .section-title {
  background: linear-gradient(135deg, #1976d2 0%, #42a5f5 100%);
  color: #fff;
}

/* 安排任务模块 - 紫色系 */
.section-card.task-section {
  background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
}

.section-card.task-section .section-title {
  background: linear-gradient(135deg, #7b1fa2 0%, #ab47bc 100%);
  color: #fff;
}

/* 历史任务模块 - 绿色系 */
.section-card.history-section {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
}

.section-card.history-section .section-title {
  background: linear-gradient(135deg, #388e3c 0%, #66bb6a 100%);
  color: #fff;
}

/* 通用标题样式 */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 0;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.08);
}

/* 分区内容区域 */
.section-content {
  padding: 24rpx;
  background-color: #fff;
}

/* 筛选条件行布局 */
.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.filter-item {
  flex: 1;
  min-width: 200rpx;
}

.filter-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

/* 选择器样式 */
.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f8f8f8;
  padding: 15rpx 20rpx;
  border-radius: 8rpx;
  width: 100%;
  box-sizing: border-box;
}

.picker-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-arrow {
  color: #999;
  font-size: 32rpx;
  margin-left: 8rpx;
}

/* 表单项 */
.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

/* 任务内容输入框 */
.task-content-input {
  width: 100%;
  min-height: 200rpx;
  padding: 15rpx 20rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.task-content-input:focus {
  background-color: #fff;
  border-color: #667eea;
}

/* 日期选择器 */
.date-picker {
  background: #f8f8f8;
}

/* 媒体上传器 */
.media-uploader {
  margin-top: 8rpx;
}

.upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  border: 2rpx dashed #ddd;
  transition: all 0.2s;
}

.upload-btn:active {
  border-color: #667eea;
  background-color: #f0f4ff;
}

.upload-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
  opacity: 0.7;
}

.upload-text {
  font-size: 26rpx;
  color: #888;
}

/* 媒体预览 */
.media-preview {
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: 8rpx;
}

.preview-video {
  width: 100%;
  max-height: 400rpx;
  border-radius: 8rpx;
}

.remove-media {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background-color: rgba(255, 77, 79, 0.95);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 77, 79, 0.4);
}

/* 提交按钮区域 */
.submit-section {
  background-color: #fff;
  padding: 20rpx;
  border-radius: 15rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: normal;
  padding: 0;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

/* 历史任务列表 - 表格样式 */
.history-section {
  background-color: #fff;
  padding: 24rpx;
  border-radius: 15rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 表格头部 */
.table-header {
  display: flex;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 8rpx 8rpx 0 0;
  padding: 16rpx 12rpx;
  margin-bottom: 2rpx;
}

.table-col-date {
  width: 140rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
  text-align: center;
}

.table-col-content {
  flex: 1;
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
  text-align: left;
  padding-left: 12rpx;
}

.table-col-attach {
  width: 100rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
  text-align: center;
}

.table-col-deadline {
  width: 100rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
  text-align: center;
}

.table-col-status {
  width: 120rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
  text-align: center;
}

/* 表格内容 */
.table-body {
  display: flex;
  flex-direction: column;
}

.table-row {
  display: flex;
  align-items: center;
  background-color: #fafafa;
  border-radius: 8rpx;
  padding: 16rpx 12rpx;
  margin-bottom: 2rpx;
  transition: all 0.2s;
}

.table-row:active {
  background-color: #f0f0f0;
}

.table-row .table-col-date {
  width: 140rpx;
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.table-row .table-col-content {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  text-align: left;
  padding-left: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-text {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.table-row .table-col-attach {
  width: 100rpx;
  text-align: center;
}

.table-row .table-col-deadline {
  width: 100rpx;
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.table-row .table-col-status {
  width: 120rpx;
  text-align: center;
}

/* 附件按钮 */
.attach-btn {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 12rpx;
  background-color: #f0f4ff;
  border-radius: 8rpx;
  border: 1rpx solid #667eea;
}

.attach-icon {
  font-size: 28rpx;
  line-height: 1;
}

.attach-text {
  font-size: 20rpx;
  color: #667eea;
  margin-top: 2rpx;
}

.no-attach {
  font-size: 28rpx;
  color: #ccc;
}

.deadline-text {
  font-size: 24rpx;
  color: #ff9800;
  font-weight: 500;
}

.no-deadline {
  font-size: 28rpx;
  color: #ccc;
}

/* 状态徽章 */
.status-badge {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.status-completed {
  background-color: #e8f5e9;
  color: #43a047;
}

.status-in-progress {
  background-color: #fff3e0;
  color: #fb8c00;
}

.status-pending {
  background-color: #f5f5f5;
  color: #757575;
}
