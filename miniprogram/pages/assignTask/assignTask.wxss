/* 容器样式 */
.assign-container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

/* 顶部标题 */
.header {
  background-color: #fff;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
  border-radius: 15rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
  display: block;
}

/* 分区卡片 */
.section-card {
  background-color: #fff;
  padding: 0;
  border-radius: 15rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

/* 两个模块的不同背景色 */
/* 安排任务模块 - 紫色系 */
.section-card.task-section {
  background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
}

.section-card.task-section .section-title {
  background: linear-gradient(135deg, #7b1fa2 0%, #ab47bc 100%);
  color: #fff;
}

/* 历史任务模块 - 绿色系 */
.section-card.history-section {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
}

.section-card.history-section .section-title {
  background: linear-gradient(135deg, #388e3c 0%, #66bb6a 100%);
  color: #fff;
}

/* 通用标题样式 */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 0;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.08);
}

/* 分区内容区域 */
.section-content {
  padding: 24rpx;
  background-color: #fff;
}

/* 历史任务内的筛选条件 */
.history-section .filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-bottom: 16rpx;
}

.history-section .filter-item {
  flex: 1;
  min-width: 150rpx;
}

.history-section .filter-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.history-section .picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f8f8f8;
  padding: 15rpx 20rpx;
  border-radius: 8rpx;
  width: 100%;
  box-sizing: border-box;
}

.history-section .picker-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-section .picker-arrow {
  color: #999;
  font-size: 32rpx;
  margin-left: 8rpx;
}

/* 历史信息显示 */
.history-info {
  padding: 12rpx 16rpx;
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.history-info text {
  font-size: 26rpx;
  color: #2e7d32;
  font-weight: 500;
}

