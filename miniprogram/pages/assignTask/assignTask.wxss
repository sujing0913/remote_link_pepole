/* 任务内容输入框 */
.task-content-input {
  width: 100%;
  min-height: 200rpx;
  padding: 15rpx 20rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.task-content-input:focus {
  background-color: #fff;
  border-color: #667eea;
}

/* 日期选择器 */
.date-picker {
  background: #f8f8f8;
}

/* 媒体上传器 */
.media-uploader {
  margin-top: 8rpx;
}

/* 上传选项容器（双按钮布局） */
.upload-options {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.upload-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  border: 2rpx dashed #ddd;
  transition: all 0.2s;
}

.upload-btn:active {
  border-color: #667eea;
  background-color: #f0f4ff;
}

/* 聊天选择按钮特殊样式 */
.upload-btn-chat {
  background-color: #f0f7ff;
  border-color: #66b3ff;
}

.upload-btn-chat:active {
  border-color: #3399ff;
  background-color: #e6f2ff;
}

.upload-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
  opacity: 0.7;
}

.upload-text {
  font-size: 24rpx;
  color: #888;
}

/* 媒体预览 */
.media-preview {
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.preview-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: 8rpx;
}

.preview-video {
  width: 100%;
  height: 400rpx;
  border-radius: 8rpx;
  background: #000;
}

/* 视频加载提示 */
.video-loading {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.7);
  padding: 20rpx 30rpx;
  border-radius: 8rpx;
  z-index: 10;
}

.video-loading text {
  color: #fff;
  font-size: 24rpx;
}

/* 未知文件类型 */
.unknown-file {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.file-icon {
  font-size: 80rpx;
  margin-bottom: 10rpx;
}

.file-name {
  font-size: 26rpx;
  color: #666;
}

.remove-media {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background-color: rgba(255, 77, 79, 0.95);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 77, 79, 0.4);
}

/* 提交按钮区域 */
.submit-section {
  background-color: #fff;
  padding: 20rpx;
  border-radius: 15rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: normal;
  padding: 0;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

/* 历史任务列表 - 表格样式 */
.history-section {
  background-color: #fff;
  padding: 24rpx;
  border-radius: 15rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 表格头部 */
.table-header {
  display: flex;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 8rpx 8rpx 0 0;
  padding: 16rpx 12rpx;
  margin-bottom: 2rpx;
}

.table-col-date {
  width: 140rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
  text-align: center;
}

.table-col-content {
  flex: 1;
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
  text-align: left;
  padding-left: 12rpx;
}

.table-col-attach {
  width: 100rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
  text-align: center;
}

.table-col-period {
  width: 140rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
  text-align: center;
}

.table-col-status {
  width: 120rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
  text-align: center;
}

/* 表格内容 */
.table-body {
  display: flex;
  flex-direction: column;
}

.table-row {
  display: flex;
  align-items: center;
  background-color: #fafafa;
  border-radius: 8rpx;
  padding: 16rpx 12rpx;
  margin-bottom: 2rpx;
  transition: all 0.2s;
}

.table-row:active {
  background-color: #f0f0f0;
}

.table-row .table-col-date {
  width: 140rpx;
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.table-row .table-col-content {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  text-align: left;
  padding-left: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-text {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.table-row .table-col-attach {
  width: 100rpx;
  text-align: center;
}

.table-row .table-col-period {
  width: 140rpx;
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.table-row .table-col-status {
  width: 120rpx;
  text-align: center;
}

/* 附件按钮 */
.attach-btn {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 12rpx;
  background-color: #f0f4ff;
  border-radius: 8rpx;
  border: 1rpx solid #667eea;
}

.attach-icon {
  font-size: 28rpx;
  line-height: 1;
}

.attach-text {
  font-size: 20rpx;
  color: #667eea;
  margin-top: 2rpx;
}

.no-attach {
  font-size: 28rpx;
  color: #ccc;
}

.period-text {
  font-size: 22rpx;
  color: #667eea;
  font-weight: 500;
}

.period-text.empty {
  font-size: 22rpx;
  color: #ff9800;
  font-weight: 400;
  border: 1rpx dashed #ff9800;
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
  background-color: rgba(255, 152, 0, 0.1);
}

/* 可点击的周期列 */
.table-col-period.clickable {
  cursor: pointer;
  position: relative;
}

.table-col-period.clickable:active {
  background-color: rgba(102, 126, 234, 0.1);
  border-radius: 8rpx;
}

/* 弹框样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  max-width: 600rpx;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
  animation: modalSlideIn 0.3s ease-out;
}

@keyframes modalSlideIn {
  from {
    transform: translateY(-50rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.modal-close {
  font-size: 40rpx;
  color: #fff;
  line-height: 1;
  padding: 0 10rpx;
}

.modal-body {
  padding: 30rpx;
}

.modal-footer {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background-color: #f8f8f8;
  border-top: 1rpx solid #eee;
}

.modal-btn {
  width: 45%;
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  background-color: #f0f0f0;
  color: #666;
}

.modal-btn.cancel:active {
  background-color: #e0e0e0;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.modal-btn.confirm:active {
  opacity: 0.8;
}

/* 状态徽章 */
.status-badge {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.status-completed {
  background-color: #e8f5e9;
  color: #43a047;
}

.status-in-progress {
  background-color: #fff3e0;
  color: #fb8c00;
}

.status-pending {
  background-color: #f5f5f5;
  color: #757575;
}
