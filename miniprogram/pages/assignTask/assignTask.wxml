<view class="assign-container">
  <!-- 顶部标题 -->
  <view class="header">
    <text class="title">📋 安排任务</text>
    <text class="subtitle">为孩子 {{childName}} 创建新任务</text>
  </view>

  <!-- 安排任务模块 -->
  <view class="section-card task-section">
    <view class="section-title">📝 安排任务</view>
    <view class="section-content">
      <!-- 科目选择 -->
      <view class="form-item">
        <text class="form-label">科目</text>
        <picker mode="selector" range="{{subjects}}" range-key="name" value="{{selectedSubjectIndex}}" bindchange="onSubjectChange">
          <view class="picker-value">
            <text class="picker-text">{{selectedSubject.name}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <!-- 任务内容输入 -->
      <view class="form-item">
        <text class="form-label">任务要求</text>
        <textarea 
          class="task-content-input" 
          placeholder="请输入任务要求，例如：完成数学练习第 1-5 题" 
          value="{{taskContent}}" 
          bindinput="onContentInput"
          maxlength="500"
          auto-height
        ></textarea>
      </view>

      <!-- 上传媒体文件 -->
      <view class="form-item">
        <text class="form-label">附加图片/视频（可选）</text>
        <view class="media-uploader">
          <!-- 已选择媒体文件 -->
          <view class="media-preview" wx:if="{{mediaPreviewUrl && mediaType}}">
            <!-- 图片预览 -->
            <block wx:if="{{mediaType === 'image'}}">
              <image class="preview-image" src="{{mediaPreviewUrl}}" mode="aspectFill" bindtap="previewMedia"></image>
              <view class="remove-media" bindtap="removeMedia">
                <text>🗑️ 删除</text>
              </view>
            </block>
            
            <!-- 视频预览 -->
            <block wx:elif="{{mediaType === 'video'}}">
              <video 
                class="preview-video" 
                src="{{mediaPreviewUrl}}" 
                controls 
                object-fit="contain"
                enable-progress-gesture="true"
                binderror="onVideoError"
                bindplay="onVideoReady"
              >
                您的浏览器不支持视频播放
              </video>
              <view class="remove-media" bindtap="removeMedia">
                <text>🗑️ 删除</text>
              </view>
            </block>
            
            <!-- 未知类型 -->
            <block wx:else>
              <view class="unknown-file">
                <text class="file-icon">📄</text>
                <text class="file-name">已选择文件</text>
              </view>
              <view class="remove-media" bindtap="removeMedia">
                <text>🗑️ 删除</text>
              </view>
            </block>
          </view>
          
          <!-- 未选择媒体文件 -->
          <view class="upload-options" wx:if="{{!mediaPreviewUrl || !mediaType}}">
            <view class="upload-btn" bindtap="chooseMedia">
              <text class="upload-icon">📷</text>
              <text class="upload-text">拍摄/相册</text>
            </view>
            <view class="upload-btn upload-btn-chat" bindtap="chooseMediaFromChat">
              <text class="upload-icon">💬</text>
              <text class="upload-text">从聊天选择</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 任务周期 -->
      <view class="form-item">
        <text class="form-label">开始日期</text>
        <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
          <view class="picker-value date-picker">
            <text>{{startDate || '选择开始日期'}}</text>
            <text class="arrow">›</text>
          </view>
        </picker>
      </view>
      
      <view class="form-item">
        <text class="form-label">结束日期</text>
        <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
          <view class="picker-value date-picker">
            <text>{{endDate || '选择结束日期'}}</text>
            <text class="arrow">›</text>
          </view>
        </picker>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button class="submit-btn" bindtap="submitTask">✅ 创建任务</button>
  </view>

  <!-- 历史任务模块 -->
  <view class="section-card history-section">
    <view class="section-title">📜 历史任务</view>
    <view class="section-content">
      <!-- 筛选条件 -->
      <view class="filter-row">
        <view class="filter-item">
          <text class="filter-label">年份</text>
          <picker mode="selector" range="{{yearOptions}}" value="{{selectedYearIndex}}" bindchange="onYearChange">
            <view class="picker-value">
              <text class="picker-text">{{yearOptions[selectedYearIndex]}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
        
        <view class="filter-item">
          <text class="filter-label">月份</text>
          <picker mode="selector" range="{{monthOptions}}" value="{{selectedMonthIndex}}" bindchange="onMonthChange">
            <view class="picker-value">
              <text class="picker-text">{{monthOptions[selectedMonthIndex]}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
      </view>

      <view class="history-info">
        <text>科目：{{selectedSubject.name}}</text>
      </view>
      
      <!-- 加载中 -->
      <view class="loading" wx:if="{{loadingTasks}}">
        <text>加载中...</text>
      </view>
      
      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{!loadingTasks && historyTasks.length === 0}}">
        <text class="empty-icon">📭</text>
        <text class="empty-text">暂无历史任务</text>
      </view>
      
    <!-- 表格头部 -->
    <view class="table-header" wx:if="{{!loadingTasks && historyTasks.length > 0}}">
      <view class="table-col-date">创建日期</view>
      <view class="table-col-content">任务要求</view>
      <view class="table-col-attach">附件</view>
      <view class="table-col-period">任务周期</view>
    </view>
    
    <!-- 表格内容 -->
    <view class="table-body" wx:if="{{!loadingTasks && historyTasks.length > 0}}">
      <view class="table-row" wx:for="{{historyTasks}}" wx:key="_id" wx:for-item="task">
        <view class="table-col-date">{{task.createDate}}</view>
        <view class="table-col-content">
          <text class="task-text">{{task.content}}</text>
        </view>
        <view class="table-col-attach">
          <view class="attach-btn" wx:if="{{task.hasMedia}}" bindtap="viewAttachment" data-task="{{task}}">
            <text class="attach-icon">{{task.mediaType === 'image' ? '🖼️' : (task.mediaType === 'video' ? '🎬' : '📄')}}</text>
            <text class="attach-text">
              {{task.mediaType === 'image' ? '图片' : (task.mediaType === 'video' ? '视频' : '文件')}}
            </text>
          </view>
          <text class="no-attach" wx:else>-</text>
        </view>
        <view class="table-col-period clickable" bindtap="showEditTaskPeriod" data-task="{{task}}">
          <text class="period-text {{task.periodText ? '' : 'empty'}}" wx:if="{{task.periodText}}">{{task.periodText}}</text>
          <text class="period-text empty" wx:else>点击设置周期</text>
        </view>
      </view>
    </view>
    </view>
  </view>

  <!-- 任务周期编辑弹框 -->
  <view class="modal-mask" wx:if="{{showTaskPeriodModal}}" bindtap="closeTaskPeriodModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">编辑任务周期</text>
        <text class="modal-close" bindtap="closeTaskPeriodModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">开始日期</text>
          <picker mode="date" value="{{taskStartDate}}" start="2020-01-01" end="2030-12-31" bindchange="onTaskStartDateChange">
            <view class="picker-value date-picker">
              <text>{{taskStartDate || '请选择开始日期'}}</text>
              <text class="arrow">›</text>
            </view>
          </picker>
        </view>
        <view class="form-item">
          <text class="form-label">结束日期</text>
          <picker mode="date" value="{{taskEndDate}}" start="2020-01-01" end="2030-12-31" bindchange="onTaskEndDateChange">
            <view class="picker-value date-picker">
              <text>{{taskEndDate || '请选择结束日期'}}</text>
              <text class="arrow">›</text>
            </view>
          </picker>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="closeTaskPeriodModal">取消</button>
        <button class="modal-btn confirm" bindtap="saveTaskPeriod">保存</button>
      </view>
    </view>
  </view>
</view>
