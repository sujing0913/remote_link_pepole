.filters {
  background-color: #fff;
  padding: 20rpx;
  border-radius: 15rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.filter-item {
  display: flex;
  align-items: center;
  background: #f8f8f8;
  padding: 15rpx 20rpx;
  border-radius: 8rpx;
}

.filter-item text {
  margin-right: 10rpx;
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
}

.filter-item .picker {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.history-container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.yearly-stats {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 15rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.stats-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.stats-grid {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 20rpx 0;
}

.stats-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
}

.stats-card .num {
  font-size: 40rpx;
  font-weight: bold;
  color: #07c160;
}

.stats-card .label {
  font-size: 24rpx;
  color: #888;
  margin-top: 10rpx;
}

.month-group {
  margin-bottom: 20rpx;
}

.month-header {
  background-color: #fff;
  padding: 24rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  border-radius: 10rpx;
}

.month-title {
  font-size: 30rpx;
  font-weight: 500;
}

.arrow {
  transition: transform 0.3s;
  color: #ccc;
}

.arrow.expanded {
  transform: rotate(90deg);
}

.table-container {
  background-color: #fff;
  overflow-x: auto;
}

.table {
  display: flex;
  flex-direction: column;
  width: 1200rpx; /* 保证表格宽度足够，容纳加宽的建议列 */
}

.tr {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
  padding: 20rpx 0;
  align-items: center;
}

.th {
  background-color: #fafafa;
  font-weight: bold;
  font-size: 26rpx;
  color: #666;
}

.td {
  padding: 0 10rpx;
  font-size: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
}

.date { width: 200rpx; }
.subject { width: 120rpx; }
.content { width: 180rpx; }
.score { width: 130rpx; }
.suggest { width: 500rpx; flex: 2; }

/* 编辑状态样式 */
.edit-input {
  border: 1rpx solid #e0e0e0;
  border-radius: 4rpx;
  width: 90%;
  height: 50rpx;
  font-size: 24rpx;
  background: #fff;
  padding: 0 5rpx;
}

.d { font-weight: 500; }
.t { font-size: 22rpx; color: #999; }

.link {
  color: #576b95;
  text-decoration: underline;
}


.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}
