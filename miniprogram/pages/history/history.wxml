<view class="history-container">
  <!-- 筛选器 -->
  <view class="filters">
    <view class="filter-row">
      <view class="filter-item">
        <text>日期：</text>
        <picker mode="selector" range="{{dateRange}}" value="{{selectedDateIndex}}" bindchange="onDateChange">
          <view class="picker">{{dateRange[selectedDateIndex]}}</view>
        </picker>
      </view>

      <view class="filter-item">
        <text>科目：</text>
        <picker mode="selector" range="{{subjectRange}}" value="{{selectedSubjectIndex}}" bindchange="onSubjectChange">
          <view class="picker">{{subjectRange[selectedSubjectIndex]}}</view>
        </picker>
      </view>

      <!-- 家长端：孩子筛选（无绑定则显示“无”） -->
      <view class="filter-item" wx:if="{{isParent}}">
        <text>孩子：</text>
        <picker mode="selector" range="{{childOptions}}" range-key="name" value="{{selectedChildIndex}}" bindchange="onChildChange">
          <view class="picker">{{childOptions[selectedChildIndex].name}}</view>
        </picker>
      </view>
    </view>
  </view>

  <!-- 年统计区域 -->
  <view class="yearly-stats">
    <view class="stats-title">{{currentYear}}年打卡统计</view>
    <view class="stats-grid">
      <view class="stats-card">
        <text class="num">{{yearlyTotal}}</text>
        <text class="label">累计打卡</text>
      </view>
      <view class="stats-card">
        <text class="num">{{totalScore}}</text>
        <text class="label">累计得分</text>
      </view>
      <view class="stats-card">
        <text class="num">{{trophyCount}}</text>
        <text class="label">奖杯</text>
      </view>
      <view class="stats-card">
        <text class="num">{{flowerCount}}</text>
        <text class="label">小红花</text>
      </view>
    </view>
  </view>

  <!-- 按月分组显示 -->
  <view class="month-groups">
    <block wx:for="{{monthGroups}}" wx:key="monthKey" wx:for-item="group">
      <!-- 月份标题栏 -->
      <view class="month-header" bindtap="toggleMonth" data-month-key="{{group.monthKey}}">
        <view class="month-title">
          <text class="expand-icon {{group.expanded ? 'expanded' : ''}}">{{group.expanded ? '▼' : '▶'}}</text>
          <text>{{group.monthName}}</text>
          <text class="month-count">({{group.count}}条记录)</text>
        </view>
        <view class="month-summary">
          <text class="month-score">得分：{{group.totalScore}}</text>
        </view>
      </view>
      
      <!-- 月份表格内容 -->
      <view class="month-table {{group.expanded ? 'expanded' : 'collapsed'}}">
        <!-- 表格头部 -->
        <view class="table-header">
          <view class="table-col-subject">科目</view>
          <view class="table-col-datetime">日期/时间</view>
          <view class="table-col-score">得分</view>
          <view class="table-col-media">内容</view>
          <view class="table-col-result">评价</view>
          <view class="table-col-ai">AI 分析</view>
        </view>
        
        <!-- 表格内容 -->
        <view class="table-body">
          <block wx:for="{{group.records}}" wx:key="_id" wx:for-item="item">
            <view class="table-row">
              <view class="table-col-subject">{{item.subject}}</view>
              <view class="table-col-datetime">
                <text>{{item.dateTimeStr}}</text>
                <text wx:if="{{item.isToday}}" class="today-tag">（今天）</text>
              </view>
          <view class="table-col-score">
            <!-- 家长查看孩子记录：显示分数，只读 -->
            <text class="score-value {{item.score >= 8 ? 'score-green' : (item.score >= 6 ? 'score-orange' : 'score-red')}}" wx:if="{{isParent}}">
              {{item.score === -1 ? '-' : item.score}}
            </text>
            <!-- 自己查看自己的记录：可编辑 -->
            <input 
              class="score-input {{item.score >= 8 ? 'score-green' : (item.score >= 6 ? 'score-orange' : 'score-red')}}" 
              value="{{item.score === -1 ? '' : item.score}}" 
              placeholder="-" 
              type="number"
              maxlength="2"
              wx:else
              bindblur="onScoreEdit" 
              data-record-id="{{item._id}}"
              data-field="score"
            />
          </view>
          <view class="table-col-media">
            <button class="action-btn media-btn" bindtap="viewMedia" data-item="{{item}}">
              <text class="btn-icon">{{item.mediaType === 'video' ? '🎬' : '🖼️'}}</text>
            </button>
          </view>
          <view class="table-col-result">
            <!-- 家长查看孩子记录：显示评价内容，只读，可点击查看 -->
            <view wx:if="{{isParent}}">
              <button class="action-btn result-btn" wx:if="{{item.aiAnalysis || item.checkResults && item.checkResults.length > 0}}" bindtap="viewCheckResult" data-item="{{item}}">
                <text class="btn-icon">📋</text>
              </button>
              <text class="no-data" wx:elif="{{!(item.aiAnalysis || (item.checkResults && item.checkResults.length > 0))}}">-</text>
            </view>
            <!-- 自己查看自己的记录：可编辑 -->
            <view wx:else>
              <input 
                class="result-input" 
                value="{{item.aiAnalysis || ''}}" 
                placeholder="输入评价" 
                bindblur="onTextEdit" 
                data-record-id="{{item._id}}"
                data-field="aiAnalysis"
              />
            </view>
          </view>
              <view class="table-col-ai">
                <!-- 家长查看孩子记录：AI 分析按钮可点击 -->
                <button class="action-btn ai-btn" wx:if="{{isParent}}" bindtap="showRatingModal" data-item="{{item}}">
                  <text class="btn-icon">⭐</text>
                </button>
                <!-- 自己查看自己的记录：可点击 -->
                <button class="action-btn ai-btn" wx:else bindtap="showRatingModal" data-item="{{item}}">
                  <text class="btn-icon">⭐</text>
                </button>
              </view>
            </view>
          </block>
        </view>
      </view>
    </block>
  </view>
  
  <view wx:if="{{records.length === 0}}" class="empty">
    {{isParent ? '暂无绑定孩子打卡记录' : '暂无打卡记录'}}
  </view>

  <!-- 检查结果弹框 -->
  <view class="check-result-modal" wx:if="{{showCheckResultModal}}" bindtap="closeCheckResultModal">
    <view class="check-result-content" catchtap="void" bindtap="void">
      <view class="check-result-header">
        <text class="check-result-title">📋 检查结果详情</text>
      </view>
      <scroll-view class="check-result-body" scroll-y="true">
        <view class="ai-result-content">
          <!-- 得分显示 -->
          <view class="result-header">
            <view class="score-display {{scoreClass}}">
              <text class="score-number">{{score}}</text>
              <text class="score-label">分</text>
            </view>
          </view>
          
          <!-- 识别内容 -->
          <view class="result-section" wx:if="{{recognizedContent || totalQuestions > 0}}">
            <view class="section-header">
              <text class="section-icon">📝</text>
              <text class="section-title">识别内容</text>
            </view>
            <!-- 英语单词打卡特殊显示格式 -->
            <view class="word-list" wx:if="{{wordList && wordList.length > 0}}">
              <view class="word-item" wx:for="{{wordList}}" wx:key="index" wx:for-item="word">
                <text class="word-cn">{{word.cn}}</text>
                <text class="word-arrow">→</text>
                <text class="word-en {{word.isCorrect ? 'correct' : 'wrong'}}">{{word.en}}</text>
                <text class="word-status" wx:if="{{!word.isCorrect}}">({{word.correct}})</text>
              </view>
            </view>
            <!-- 普通识别内容显示 -->
            <view class="content-box highlighted" wx:if="{{recognizedContent && (!wordList || wordList.length === 0)}}">{{recognizedContent}}</view>
            <view class="question-stats" wx:if="{{totalQuestions > 0}}">
              <text class="stat-item">共 {{totalQuestions}} 道题</text>
              <text class="stat-item correct">正确 {{correctQuestions}} 道</text>
              <text class="stat-item wrong">错误 {{totalQuestions - correctQuestions}} 道</text>
            </view>
          </view>
          
          <!-- 判断结果 -->
          <view class="result-section" wx:if="{{aiAnalysis}}">
            <view class="section-header">
              <text class="section-icon">{{score >= 6 ? '✅' : '⚠️'}}</text>
              <text class="section-title">判断结果</text>
            </view>
            <view class="judgment-box {{score >= 6 ? 'correct' : 'incorrect'}}">
              <text class="judgment-text">{{score >= 8 ? '✓ 非常棒！' : (score >= 6 ? '✓ 还不错' : '✗ 需要加油')}}</text>
              <view class="judgment-detail">{{aiAnalysis}}</view>
            </view>
          </view>
          
          <!-- 检查结果详情 -->
          <view class="result-section" wx:if="{{checkResults && checkResults.length > 0}}">
            <view class="section-header">
              <text class="section-icon">📋</text>
              <text class="section-title">检查结果详情</text>
            </view>
            <view class="check-result-list">
              <block wx:for="{{checkResults}}" wx:key="index" wx:for-item="result">
                <view class="check-result-item {{result.is_correct ? 'correct' : 'wrong'}}">
                  <view class="check-item-header">
                    <text class="check-item-icon">{{result.is_correct ? '✅' : '❌'}}</text>
                    <text class="check-item-status">{{result.is_correct ? '正确' : '错误'}}</text>
                  </view>
                  <view class="check-item-content">
                    <view class="check-item-row">
                      <text class="check-label">题目：</text>
                      <text class="check-value">{{result.question}}</text>
                    </view>
                    <view class="check-item-row">
                      <text class="check-label">你的答案：</text>
                      <text class="check-value {{result.is_correct ? '' : 'wrong-answer'}}">{{result.user_answer}}</text>
                    </view>
                    <view class="check-item-row" wx:if="{{!result.is_correct}}">
                      <text class="check-label">正确答案：</text>
                      <text class="check-value correct-answer">{{result.correct_answer}}</text>
                    </view>
                  </view>
                </view>
              </block>
            </view>
          </view>
          
        </view>
      </scroll-view>
      <button class="check-result-close-btn" bindtap="closeCheckResultModal">关闭</button>
    </view>
  </view>

  <!-- AI 评分加载中弹框 -->
  <view class="ai-loading-mask" wx:if="{{showAILoading}}">
    <view class="ai-loading-content">
      <view class="loading-header">正在检查评分...</view>
      <view class="loading-spinner">
        <view class="spinner-circle"></view>
        <view class="loading-animal">{{currentAnimal}}</view>
      </view>
    </view>
  </view>

  <!-- 手动评分弹框 -->
  <view class="manual-rating-modal" wx:if="{{showManualRatingModal}}" bindtap="closeManualRatingModal">
    <view class="manual-rating-content" catchtap="stopManualModalTap">
      <view class="manual-rating-header">
        <text class="manual-rating-title">✏️ 手动评分</text>
      </view>
      <scroll-view class="manual-rating-body" scroll-y="true">
        <view class="form-item">
          <text class="item-label">得分（0-10 分）</text>
          <input 
            class="score-input" 
            type="number" 
            placeholder="请输入得分" 
            value="{{manualRatingScore}}"
            bindinput="onManualScoreInput"
            maxlength="2"
          />
        </view>
        <view class="form-item">
          <text class="item-label">评价</text>
          <textarea 
            class="evaluation-textarea" 
            placeholder="请输入评价内容" 
            value="{{manualRatingEvaluation}}"
            bindinput="onManualEvaluationInput"
            maxlength="200"
          />
        </view>
      </scroll-view>
      <view class="manual-rating-footer">
        <button class="btn btn-cancel" bindtap="closeManualRatingModal">取消</button>
        <button class="btn btn-save" bindtap="saveManualRating">保存</button>
      </view>
    </view>
  </view>

  <!-- AI 评分选择弹框 -->
  <view class="rating-choice-modal" wx:if="{{showRatingChoice}}" bindtap="closeRatingModal">
    <view class="rating-choice-content" catchtap="void">
      <view class="rating-choice-title">选择评分方式</view>
      <view class="rating-choice-options">
        <view class="rating-choice-option" bindtap="onAIAssessment">
          <view class="option-icon">🤖</view>
          <view class="option-text">AI 自动评分</view>
          <view class="option-desc">智能识别图片，自动评分并给出建议</view>
        </view>
        <view class="rating-choice-option" bindtap="onManualAssessment">
          <view class="option-icon">✍️</view>
          <view class="option-text">手动评分</view>
          <view class="option-desc">手动输入分数和评价</view>
        </view>
      </view>
      <button class="rating-choice-cancel" bindtap="closeRatingModal">取消</button>
    </view>
  </view>

  <!-- AI 评分结果自定义弹框（支持滚动） -->
  <view class="ai-modal-mask" wx:if="{{showAIResultModal}}" catchtap="closeAIResultModal">
    <view class="ai-modal-container" catchtap="stopPropagation">
      <view class="ai-modal-header">
        <text class="ai-modal-title">🎉 AI 评分完成</text>
      </view>
      <scroll-view class="ai-modal-content" scroll-y="true">
        <view class="ai-modal-body">
          <!-- 得分显示 -->
          <view class="result-header">
            <view class="score-display {{aiScoreClass}}">
              <text class="score-number">{{aiScore}}</text>
              <text class="score-label">分</text>
            </view>
          </view>
          
          <!-- 识别内容 -->
          <view class="result-section" wx:if="{{aiRecognizedContent || aiTotalQuestions > 0}}">
            <view class="section-header">
              <text class="section-icon">📝</text>
              <text class="section-title">识别内容</text>
            </view>
            <!-- 英语单词打卡特殊显示格式 -->
            <view class="word-list" wx:if="{{aiWordList && aiWordList.length > 0}}">
              <view class="word-item" wx:for="{{aiWordList}}" wx:key="index" wx:for-item="word">
                <text class="word-cn">{{word.cn}}</text>
                <text class="word-arrow">→</text>
                <text class="word-en {{word.isCorrect ? 'correct' : 'wrong'}}">{{word.en}}</text>
                <text class="word-status" wx:if="{{!word.isCorrect}}">({{word.correct}})</text>
              </view>
            </view>
            <!-- 普通识别内容显示 -->
            <view class="content-box highlighted" wx:if="{{aiRecognizedContent && (!aiWordList || aiWordList.length === 0)}}">{{aiRecognizedContent}}</view>
            <view class="question-stats" wx:if="{{aiTotalQuestions > 0}}">
              <text class="stat-item">共 {{aiTotalQuestions}} 道题</text>
              <text class="stat-item correct">正确 {{aiCorrectQuestions}} 道</text>
              <text class="stat-item wrong">错误 {{aiTotalQuestions - aiCorrectQuestions}} 道</text>
            </view>
          </view>
          
          <!-- 判断结果 -->
          <view class="result-section" wx:if="{{aiJudgment}}">
            <view class="section-header">
              <text class="section-icon">{{aiScore >= 6 ? '✅' : '⚠️'}}</text>
              <text class="section-title">判断结果</text>
            </view>
            <view class="judgment-box {{aiScore >= 6 ? 'correct' : 'incorrect'}}">
              <text class="judgment-text">{{aiScore >= 8 ? '✓ 非常棒！' : (aiScore >= 6 ? '✓ 还不错' : '✗ 需要加油')}}</text>
              <view class="judgment-detail">{{aiJudgment}}</view>
            </view>
          </view>
          
          <!-- 检查结果详情 -->
          <view class="result-section" wx:if="{{aiCheckResults && aiCheckResults.length > 0}}">
            <view class="section-header">
              <text class="section-icon">📋</text>
              <text class="section-title">检查结果详情</text>
            </view>
            <view class="check-result-list">
              <block wx:for="{{aiCheckResults}}" wx:key="index" wx:for-item="result">
                <view class="check-result-item {{result.is_correct ? 'correct' : 'wrong'}}">
                  <view class="check-item-header">
                    <text class="check-item-icon">{{result.is_correct ? '✅' : '❌'}}</text>
                    <text class="check-item-status">{{result.is_correct ? '正确' : '错误'}}</text>
                  </view>
                  <view class="check-item-content">
                    <view class="check-item-row">
                      <text class="check-label">题目：</text>
                      <text class="check-value">{{result.question}}</text>
                    </view>
                    <view class="check-item-row">
                      <text class="check-label">你的答案：</text>
                      <text class="check-value {{result.is_correct ? '' : 'wrong-answer'}}">{{result.user_answer}}</text>
                    </view>
                    <view class="check-item-row" wx:if="{{!result.is_correct}}">
                      <text class="check-label">正确答案：</text>
                      <text class="check-value correct-answer">{{result.correct_answer}}</text>
                    </view>
                  </view>
                </view>
              </block>
            </view>
          </view>
          
        </view>
      </scroll-view>
      <view class="ai-modal-footer">
        <button class="ai-modal-btn ai-modal-btn-outline" wx:if="{{fileType === 'image'}}" bindtap="viewOriginalImage">查看原图</button>
        <button class="ai-modal-btn ai-modal-btn-outline" bindtap="closeAIResultModal">取消</button>
        <button class="ai-modal-btn ai-modal-btn-primary" bindtap="saveAIResult">保存</button>
      </view>
    </view>
  </view>
</view>
