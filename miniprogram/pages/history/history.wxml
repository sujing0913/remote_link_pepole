<view class="history-container">
  <!-- 筛选器 -->
  <view class="filters">
    <view class="filter-item">
      <text>日期：</text>
      <picker mode="multiSelector" range="{{yearMonthRange}}" value="{{selectedYearMonth}}" bindchange="onYearMonthChange">
        <view class="picker">
          {{yearMonthRange[0][selectedYearMonth[0]]}}年{{yearMonthRange[1][selectedYearMonth[1]] === '全部' ? '全部月份' : yearMonthRange[1][selectedYearMonth[1]] + '月'}}
        </view>
      </picker>
    </view>
    <view class="filter-item">
      <text>队友：</text>
      <picker mode="selector" range="{{participantList}}" range-key="nickName" value="{{selectedParticipantIndex}}" bindchange="onParticipantFilterChange">
        <view class="picker">{{selectedParticipantIndex < participantList.length ? participantList[selectedParticipantIndex].nickName : '全部队友'}}</view>
      </picker>
    </view>
  </view>

  <!-- 年统计区域 -->
  <view class="yearly-stats">
    <view class="stats-title">{{currentYear}}年打卡统计</view>
    <view class="stats-grid">
      <view class="stats-card">
        <text class="num">{{yearlyTotal}}</text>
        <text class="label">累计打卡</text>
      </view>
      <view class="stats-card">
        <text class="num">{{totalScore}}</text>
        <text class="label">累计得分</text>
      </view>
      <view class="stats-card">
        <text class="num">{{trophyCount}}</text>
        <text class="label">奖杯</text>
      </view>
      <view class="stats-card">
        <text class="num">{{flowerCount}}</text>
        <text class="label">小红花</text>
      </view>
    </view>
  </view>

  <!-- 历史记录表格 -->
  <view class="history-list">
    <block wx:for="{{groupedRecords}}" wx:key="month" wx:for-item="monthGroup">
      <view class="month-group">
        <view class="month-header" bindtap="toggleMonth" data-month="{{monthGroup.month}}">
          <text class="month-title">{{monthGroup.month}} ({{monthGroup.records.length}}次)</text>
          <text class="arrow {{monthGroup.collapsed ? '' : 'expanded'}}">></text>
        </view>
        
        <view class="table-container" hidden="{{monthGroup.collapsed}}">
          <view class="table">
            <view class="tr th">
              <view class="td date">日期/时间</view>
              <view class="td teammate">队友</view>
              <view class="td subject">科目</view>
              <view class="td content">内容</view>
              <view class="td score">评分</view>
              <view class="td suggest">建议</view>
            </view>
            <view class="tr" wx:for="{{monthGroup.records}}" wx:key="_id">
              <view class="td date">
                <text class="d">{{item.dateStr}}</text>
                <text class="t">{{item.timeStr}}</text>
              </view>
              <view class="td teammate">{{item.participantNickName}}</view>
              <view class="td subject">{{item.subject}}</view>
              <view class="td content">
                <text class="link" bindtap="viewMedia" data-item="{{item}}">查看{{item.mediaType === 'video' ? '视频' : '照片'}}</text>
              </view>
              <view class="td score">
                <input class="edit-input" type="number" value="{{item.score === -1 ? '' : item.score}}" placeholder="评分" bindblur="onScoreBlur" data-id="{{item._id}}" />
              </view>
              <view class="td suggest">
                <input class="edit-input" value="{{item.suggestion}}" placeholder="输入建议" bindblur="onSuggestBlur" data-id="{{item._id}}" />
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>
  
  <view wx:if="{{groupedRecords.length === 0}}" class="empty">暂无打卡记录</view>
</view>
