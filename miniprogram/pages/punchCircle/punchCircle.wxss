/* 朋友圈风格样式 */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部标题 */
.header {
  padding: 30rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  margin-bottom: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
  word-break: break-all;
  overflow-wrap: break-word;
}

.subtitle {
  font-size: 28rpx;
  opacity: 0.9;
  word-break: break-all;
  overflow-wrap: break-word;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 打卡圈列表 */
.post-list {
  padding: 20rpx;
  height: calc(100vh - 200rpx);
  width: 100%;
  box-sizing: border-box;
}

/* 帖子卡片 */
.post-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 用户信息行 */
.user-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 40rpx;
}

/* 用户信息 */
.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.subject-tag {
  display: inline-block;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-top: 8rpx;
  width: fit-content;
}

/* 发布时间 */
.post-time {
  font-size: 24rpx;
  color: #999;
}

/* 内容区域 */
.content-section {
  margin-bottom: 20rpx;
}

/* 媒体内容 */
.media-content {
  margin-bottom: 16rpx;
}

.post-image {
  width: 100%;
  max-height: 500rpx;
  border-radius: 12rpx;
}

.post-video {
  width: 100%;
  max-height: 500rpx;
  border-radius: 12rpx;
}

/* 文字内容 */
.text-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  padding: 16rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
}

/* 互动区域 */
.interaction-row {
  display: flex;
  gap: 40rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
}

.action-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  font-size: 28rpx;
  color: #666;
}

.action-btn text.liked {
  color: #ff4757;
}

/* 评论列表 */
.comments-section {
  padding-top: 16rpx;
}

.comment-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 10rpx;
}

.comment-user {
  font-weight: 600;
  color: #333;
  margin-right: 8rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* 评论弹框 */
.comment-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.comment-modal {
  width: 100%;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  max-height: 60vh;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.close-btn {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.comment-input {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.comment-submit {
  margin-top: 20rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}
