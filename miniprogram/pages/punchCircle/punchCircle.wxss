/* 朋友圈风格样式 */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部标题 */
.header {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  margin-bottom: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.header-left {
  flex: 1;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
  word-break: break-all;
  overflow-wrap: break-word;
}

.subtitle {
  font-size: 28rpx;
  opacity: 0.9;
  word-break: break-all;
  overflow-wrap: break-word;
}

/* 头部右侧 - 科目选择和公开状态（同一行） */
.header-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

/* 科目选择器 */
.subject-picker {
  min-width: 180rpx;
}

.picker-display {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.picker-value {
  font-weight: 600;
  margin: 0 8rpx;
}

.picker-arrow {
  font-size: 20rpx;
  margin-left: 4rpx;
}

/* 公开状态 */
.public-status {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  cursor: pointer;
}

.status-label {
  margin-right: 8rpx;
}

.status-value {
  font-weight: 600;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.status-value.on {
  background-color: rgba(76, 175, 80, 0.8);
  color: #fff;
}

.status-value.off {
  background-color: rgba(158, 158, 158, 0.8);
  color: #fff;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 打卡圈列表 */
.post-list {
  padding: 20rpx;
  height: calc(100vh - 200rpx);
  width: 100%;
  box-sizing: border-box;
}

/* 帖子卡片 */
.post-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 用户信息行 */
.user-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 40rpx;
}

/* 用户信息 */
.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.subject-tag {
  display: inline-block;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-top: 8rpx;
  width: fit-content;
}

/* 发布时间 */
.post-time {
  font-size: 24rpx;
  color: #999;
}

/* 内容区域 */
.content-section {
  margin-bottom: 20rpx;
}

/* 媒体内容 */
.media-content {
  margin-bottom: 16rpx;
}

.post-image {
  width: 100%;
  max-height: 500rpx;
  border-radius: 12rpx;
}

.post-video {
  width: 100%;
  max-height: 500rpx;
  border-radius: 12rpx;
}

/* 文字内容 */
.text-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  padding: 16rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
}

/* 点赞按钮（用户信息行内 - 最右侧） */
.user-row .like-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 12rpx;
  margin-left: 16rpx; /* 与时间保持间距 */
}

.user-row .like-btn text {
  font-size: 28rpx;
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  line-height: 1;
}

.user-row .like-btn:active {
  transform: scale(0.95);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* 设置弹框 */
.settings-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.settings-modal {
  width: 80%;
  max-width: 600rpx;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
}

.settings-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.settings-content {
  padding: 10rpx 0;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.setting-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-right: 20rpx;
}

.setting-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.setting-desc {
  font-size: 24rpx;
  color: #999;
}

.setting-switch {
  transform: scale(0.9);
}

.setting-hint {
  margin-top: 20rpx;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.settings-footer {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.save-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}
