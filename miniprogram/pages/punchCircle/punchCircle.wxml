<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <view class="header-left">
      <text class="title">今日打卡圈</text>
    </view>
    <!-- 公开状态和科目选择 -->
    <view class="header-right">
      <picker class="subject-picker" mode="selector" range="{{subjects}}" value="{{selectedSubjectIndex}}" bindchange="onSubjectChange">
        <view class="picker-display">
          <text>科目：</text>
          <text class="picker-value">{{subjects[selectedSubjectIndex]}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
      <view class="public-status" bindtap="openSettings">
        <text class="status-label">公开：</text>
        <text class="status-value {{punchCirclePublic ? 'on' : 'off'}}">{{punchCirclePublic ? '是' : '否'}}</text>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <!-- 打卡圈列表 -->
  <scroll-view class="post-list" scroll-y="true" wx:if="{{!loading && posts.length > 0}}">
    <block wx:for="{{posts}}" wx:key="_id" wx:for-item="post">
      <view class="post-card">
        <!-- 用户信息行（包含点赞按钮） -->
        <view class="user-row">
          <!-- 头像 -->
          <view class="avatar">
            <image wx:if="{{post.userInfo.avatarUrl}}" src="{{post.userInfo.avatarUrl}}" mode="aspectFill"></image>
            <text wx:else class="avatar-placeholder">👤</text>
          </view>
          <!-- 昵称和科目 -->
          <view class="user-info">
            <text class="nickname">{{post.userInfo.nickName}}</text>
            <view class="subject-tag">
              <text>{{post.subject}}</text>
            </view>
          </view>
          <!-- 时间和日期 -->
          <text class="post-time">{{formatDateTime(post.createTime)}}</text>
          <!-- 点赞按钮（小红花） -->
          <view class="action-btn like-btn" bindtap="onLike" data-post-id="{{post._id}}" data-is-liked="{{post.isLiked}}">
            <text class="{{post.isLiked ? 'liked' : ''}}">
              🌺 {{post.likeCount || 0}}
            </text>
          </view>
        </view>

        <!-- 打卡内容 -->
        <view class="content-section">
          <!-- 如果有媒体内容 -->
          <view class="media-content" wx:if="{{post.mediaUrl}}">
            <!-- 图片类型 -->
            <image 
              class="post-image" 
              src="{{post.mediaUrl}}" 
              mode="aspectFill" 
              bindtap="previewMedia" 
              data-url="{{post.mediaUrl}}"
              data-post="{{post}}"
              wx:if="{{post.mediaType === 'image'}}"
            ></image>
            <!-- 视频类型 -->
            <video 
              class="post-video" 
              src="{{post.mediaUrl}}" 
              controls 
              show-center-play-btn
              enable-progress-gesture
              object-fit="contain"
              bindtap="previewMedia"
              data-url="{{post.mediaUrl}}"
              data-post="{{post}}"
              wx:elif="{{post.mediaType === 'video'}}"
            ></video>
          </view>
          
          <!-- 显示文字内容 -->
          <view class="text-content" wx:if="{{post.recognizedContent}}">
            <text>{{post.recognizedContent}}</text>
          </view>
        </view>

      </view>
    </block>
  </scroll-view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && posts.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">今天还没有人打卡</text>
    <text class="empty-hint">快去打卡成为第一个吧！</text>
  </view>

  <!-- 设置弹框 -->
  <view class="settings-modal-mask" wx:if="{{showSettingsModal}}" bindtap="closeSettings">
    <view class="settings-modal" catchtap="void">
      <view class="settings-header">
        <text>打卡圈隐私设置</text>
        <text class="close-btn" bindtap="closeSettings">✕</text>
      </view>
      <view class="settings-content">
        <view class="setting-item">
          <view class="setting-info">
            <text class="setting-title">公开打卡内容</text>
            <text class="setting-desc">开启后，您的打卡内容将对所有人可见</text>
          </view>
          <switch 
            class="setting-switch" 
            checked="{{punchCirclePublic}}" 
            bindchange="onPublicSwitchChange"
            color="#07c160"
          />
        </view>
        <view class="setting-hint">
          <text>💡 关闭时，只有绑定的家长和同一家长下的孩子可以看到您的打卡内容</text>
        </view>
      </view>
      <view class="settings-footer">
        <button class="save-btn" bindtap="saveSettings">保存</button>
      </view>
    </view>
  </view>
</view>
