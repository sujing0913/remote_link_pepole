.container {
  padding: 24rpx;
  min-height: 100vh;
  background: #f6f6f6;
  box-sizing: border-box;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx; /* 间隔更均匀 */
  margin-bottom: 20rpx;
}

.filters {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 12rpx; /* 两个下拉间距更均匀 */
  flex-wrap: nowrap; /* 顶部选项固定同一行 */
  flex: 1;
  padding-right: 16rpx; /* 再缩小右侧留白 */
  border-right: 1rpx solid #e9e9e9; /* 分隔线 */
  margin-right: 12rpx;
  min-width: 0;
}

/* 顶部：右侧添加按钮（保持靠右，与左侧过滤有明显间隔） */
.add-btn {
  margin-left: 0;
  flex: 0 0 auto;
  padding-left: 0;
}

.filter {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.picker {
  padding: 12rpx 16rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.picker.small {
  padding: 10rpx 14rpx;
  font-size: 24rpx;
}

/* 列表内的“记忆状态”下拉框：更像可点击控件 */
.picker.dropdown {
  display: inline-flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  min-width: 140rpx;
  padding: 10rpx 16rpx;
  font-size: 24rpx;
  border: 1rpx solid #dcdcdc;
  background: #fff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

/* 顶部过滤区下拉：更紧凑一些，但保持“可选择”的控件感 */
.filter-dd {
  width: 220rpx; /* 再缩小下拉长度，顶部更紧凑 */
  min-width: 220rpx;
  padding: 10rpx 12rpx;
  font-size: 25rpx;
  border-color: #cfd6e4;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.arrow {
  font-size: 22rpx;
  color: #666;
}

.add-btn {
  background: #07c160;
  color: #fff;
  border-radius: 16rpx;
  padding: 10rpx 20rpx;
  white-space: nowrap;
  box-shadow: 0 2rpx 10rpx rgba(7, 193, 96, 0.25);
}

.list {
  height: calc(100vh - 120rpx);
}

.month-section {
  margin-bottom: 22rpx;
}

.month-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin: 12rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 14rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.6);
}

.month-text {
  flex: 1;
}

.month-arrow {
  flex: 0 0 auto;
  font-size: 26rpx;
  color: #666;
}

.card {
  background: #fff;
  border-radius: 18rpx;
  padding: 18rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 未记会（否）：整卡标红（不改变布局，仅强调） */
.card-unremembered {
  border: 2rpx solid rgba(244, 67, 54, 0.45);
}

.card-unremembered .word,
.card-unremembered .value,
.card-unremembered .label {
  color: #d93025;
}

.row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 12rpx;
}

.row-head {
  margin-top: 0;
  align-items: center;
  justify-content: space-between;
}

.row-inline {
  align-items: center;
}

.hint {
  font-size: 22rpx;
  color: #999;
}

.word {
  font-size: 38rpx;
  font-weight: 800;
  color: #222;
}

.actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.mini-btn {
  padding: 0 18rpx;
  border-radius: 14rpx;
}

.label {
  width: 140rpx;
  flex: 0 0 140rpx;
  font-size: 24rpx;
  color: #666;
}

.value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
  white-space: pre-wrap;
  word-break: break-word;
}

.remark {
  flex: 1;
  min-height: 72rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 12rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.empty {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
}

.empty-text {
  color: #999;
  font-size: 26rpx;
}

/* modal */
.modal-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
}

.modal {
  width: 100%;
  max-width: 680rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-sizing: border-box;
  max-height: 86vh;
  overflow: auto;
}

/* 复用 scanWord 的结果展示样式（局部） */
.word-result {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 18rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.word-header {
  text-align: center;
  padding-bottom: 26rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 26rpx;
}

.word-main {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.word-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.play-audio-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.35);
}

.play-audio-btn::after {
  border: none;
}

.audio-icon {
  font-size: 40rpx;
}

.phonetic-container {
  display: flex;
  justify-content: center;
}

.phonetic-symbol {
  font-size: 28rpx;
  color: #666;
  background-color: #f5f5f5;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.word-section {
  margin-bottom: 26rpx;
}

.word-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  display: flex;
  align-items: center;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  background-color: #f8f9fa;
  padding: 20rpx;
  border-radius: 12rpx;
}

.section-content.memory-tip {
  background-color: #fff9e6;
  border-left: 4rpx solid #ffbb00;
}

.sentence-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.sentence-item {
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  border-left: 4rpx solid #667eea;
}

.sentence-en {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  line-height: 1.6;
}

.sentence-cn {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* loading（复用 scanWord） */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 0 10rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #222;
  margin-bottom: 16rpx;
  text-align: center;
}

.modal-row {
  display: flex;
  gap: 14rpx;
  align-items: center;
}

/* AI 结果区滚动容器：避免弹框内容过长导致显示不全 */
.ai-result-scroll {
  margin-top: 18rpx;
  max-height: 48vh;
}

.input {
  flex: 1;
  height: 76rpx;
  background: #f7f7f7;
  border-radius: 14rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
}

.ai-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 14rpx;
  padding: 0 16rpx;
  height: 76rpx;
  line-height: 76rpx;
}

.ai-preview {
  margin-top: 18rpx;
  background: #f8fbff;
  border-radius: 16rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(24, 144, 255, 0.2);
}

.preview-row {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.preview-row:first-child {
  margin-top: 0;
}

.p-label {
  flex: 0 0 160rpx;
  width: 160rpx;
  color: #666;
  font-size: 24rpx;
}

.p-value {
  flex: 1;
  color: #333;
  font-size: 26rpx;
  white-space: pre-wrap;
  word-break: break-word;
}

.p-sub {
  flex: 0 0 auto;
  color: #999;
  font-size: 24rpx;
}

.preview-block {
  margin-top: 14rpx;
}

.block-title {
  margin-bottom: 8rpx;
  font-weight: 700;
}

.sentence {
  padding: 10rpx 12rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-top: 10rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.s-en {
  font-size: 26rpx;
  color: #222;
  line-height: 1.5;
}

.s-cn {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.modal-actions {
  margin-top: 22rpx;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.cancel {
  background: #f2f2f2;
  color: #333;
  border-radius: 16rpx;
  padding: 12rpx 22rpx;
}

.confirm {
  background: #07c160;
  color: #fff;
  border-radius: 16rpx;
  padding: 12rpx 22rpx;
}
