/* ========== 页面容器 ========== */
page {
  background-color: #f8f8f8;
}

.container {
  padding: 16rpx;
  background-color: #f8f8f8;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* ========== 统计卡片模块（参考规范文档） ========== */
.stats-card {
  background-color: #fff;
  padding: 24rpx 20rpx;
  border-radius: 15rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.stats-group {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 80rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  line-height: 1.2;
}

.stat-total {
  color: #667eea;
}

.stat-remember {
  color: #07c160;
}

.stat-forgot {
  color: #ff4d4f;
}

.stat-label {
  font-size: 22rpx;
  color: #888;
  margin-top: 4rpx;
  text-align: center;
  line-height: 1.3;
}

.stats-card .add-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 36rpx;
  padding: 0 28rpx;
  height: 68rpx;
  line-height: 68rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.35);
  flex: 0 0 auto;
  white-space: nowrap;
}

.stats-card .add-btn::after {
  border: none;
}

/* ========== 筛选器模块（参考规范文档） ========== */
.filters {
  background-color: #fff;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
}

.filter-row {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  width: 100%;
}

.filter-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f8f8f8;
  padding: 14rpx 18rpx;
  border-radius: 8rpx;
  flex: 1;
  min-width: 0;
}

.filter-item text {
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
  margin-right: 10rpx;
  font-weight: 500;
  flex: 0 0 auto;
}

.filter-item .picker {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  white-space: nowrap;
  text-align: right;
  min-width: 80rpx;
}

/* ========== 月份分组模块（参考规范文档） ========== */
.month-section {
  margin-bottom: 20rpx;
}

.month-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx 25rpx;
  margin-bottom: 2rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.month-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.month-arrow {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  transition: transform 0.3s ease;
}

/* ========== 单词卡片模块 ========== */
.card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 未记会状态：左侧红色边框，浅红背景 */
.card-unremembered {
  border-left: 4rpx solid #ff4d4f;
  background-color: #fff2f0;
}

.card-unremembered .word {
  color: #ff4d4f;
}

/* 单词行（标题 + 操作） */
.row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 12rpx;
}

.row-head {
  margin-top: 0;
  align-items: center;
  justify-content: space-between;
}

.row-inline {
  align-items: center;
}

.word {
  font-size: 36rpx;
  font-weight: 800;
  color: #333;
}

.actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.mini-btn {
  padding: 0 18rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
  color: #333;
}

.mini-btn::after {
  border: none;
}

/* 标签和值 */
.label {
  width: 120rpx;
  flex: 0 0 120rpx;
  font-size: 24rpx;
  color: #666;
  white-space: nowrap;
}

.value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  white-space: pre-wrap;
  word-break: break-word;
}

/* 是否记会选择器 */
.picker.dropdown {
  display: inline-flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  min-width: 140rpx;
  padding: 10rpx 16rpx;
  font-size: 24rpx;
  border: 1rpx solid #dcdcdc;
  background: #fff;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.arrow {
  font-size: 20rpx;
  color: #666;
}

.hint {
  font-size: 22rpx;
  color: #999;
  margin-left: 8rpx;
}

/* 备注输入框 */
.remark {
  flex: 1;
  min-height: 72rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 12rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  border: 1rpx solid #e0e0e0;
}

.remark:focus {
  border-color: #667eea;
  background-color: #fff;
}

/* ========== 空状态 ========== */
.empty {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

/* ========== 列表滚动区域 ========== */
.list {
  flex: 1;
  min-height: 0;
}

/* ========== 弹框模块（参考规范文档） ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
}

.modal {
  width: 100%;
  max-width: 600rpx;
  max-height: 80vh;
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 10rpx 60rpx rgba(0, 0, 0, 0.3);
  animation: modalSlideIn 0.3s ease-out;
}

@keyframes modalSlideIn {
  from {
    opacity: 0;
    transform: translateY(-50rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.modal-row {
  display: flex;
  gap: 14rpx;
  align-items: center;
  padding: 20rpx;
}

.input {
  flex: 1;
  height: 80rpx;
  background: #f7f7f7;
  border-radius: 14rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  border: 1rpx solid #e0e0e0;
}

.input:focus {
  border-color: #667eea;
  background-color: #fff;
}

.ai-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 14rpx;
  padding: 0 20rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

.ai-btn::after {
  border: none;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

/* AI 结果滚动区 */
.ai-result-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 0 20rpx 20rpx;
}

.word-result {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.word-header {
  text-align: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.word-main {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.word-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.play-audio-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.35);
}

.play-audio-btn::after {
  border: none;
}

.audio-icon {
  font-size: 36rpx;
}

.phonetic-container {
  display: flex;
  justify-content: center;
}

.phonetic-symbol {
  font-size: 28rpx;
  color: #666;
  background-color: #f5f5f5;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.word-section {
  margin-bottom: 20rpx;
}

.word-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  background-color: #f8f9fa;
  padding: 16rpx;
  border-radius: 12rpx;
}

.section-content.memory-tip {
  background-color: #fff9e6;
  border-left: 4rpx solid #ffbb00;
}

.sentence-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.sentence-item {
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 16rpx;
  border-left: 4rpx solid #667eea;
}

.sentence-en {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.sentence-cn {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

/* 弹框底部按钮 */
.modal-actions {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 30rpx 30rpx;
  background-color: #fff;
}

.modal-actions .cancel,
.modal-actions .confirm {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-actions .cancel {
  background-color: #f5f5f5;
  color: #666;
  border: 2rpx solid #ddd;
}

.modal-actions .confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.modal-actions .cancel::after,
.modal-actions .confirm::after {
  border: none;
}

.modal-actions .cancel:active,
.modal-actions .confirm:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.modal-actions .confirm[disabled] {
  opacity: 0.5;
}
