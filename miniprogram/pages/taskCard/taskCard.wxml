<view class="container">
  <!-- 顶部标题卡片 -->
  <view class="header-card">
    <view class="header-top">
      <view class="header-title">📋 任务卡</view>
      <view class="role-tag {{asParent ? 'parent' : (asChild ? 'child' : 'guest')}}">{{roleText}}</view>
    </view>
    <view class="header-subtitle">{{weekInfo || '加载中...'}}</view>
    
    <!-- 家长端：孩子选择器 -->
    <view class="child-selector" wx:if="{{asParent && children.length > 0}}">
      <picker class="child-picker" value="{{selectedChildIndex}}" range="{{children}}" range-key="childName" bindchange="onChildChange">
        <view class="picker-display">
          <text class="picker-label">👦 选择孩子：</text>
          <text class="picker-value">{{selectedChild ? selectedChild.childName : '请选择'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 任务列表 -->
  <view class="task-list">
    <!-- 加载中 -->
    <view class="loading" wx:if="{{loading}}">
      <text class="loading-icon">⏳</text>
      <text class="loading-text">加载中...</text>
    </view>
    
    <!-- 空状态 -->
    <view class="empty" wx:if="{{!loading && tasks.length === 0}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无任务</text>
      <text class="empty-hint" wx:if="{{asParent}}">家长还没有为 {{selectedChild ? selectedChild.childName : '孩子'}} 安排任务哦</text>
      <text class="empty-hint" wx:else>家长还没有为你安排任务哦</text>
    </view>

    <!-- 任务列表 -->
    <view class="task-card" wx:for="{{tasks}}" wx:key="_id" wx:for-item="task">
      <!-- 任务头部：科目和日期 -->
      <view class="task-header">
        <view class="subject-tag task-subject">{{task.subject}}</view>
        <view class="task-date">{{task.createTime}}</view>
      </view>
      
      <!-- 任务内容 -->
      <view class="task-content">
        <view class="content-text">{{task.content}}</view>
      </view>
      
      <!-- 截止日期 -->
      <view class="task-deadline" wx:if="{{task.deadline}}">
        <text class="deadline-icon">⏰</text>
        <text class="deadline-text">截止：{{task.deadline}}</text>
      </view>
      
      <!-- 附件显示区域：支持图片和视频 -->
      <view class="task-attachment" wx:if="{{task.mediaUrl}}">
        <!-- 图片附件 -->
        <view class="attachment-container" wx:if="{{task.mediaType === 'image'}}">
          <image 
            class="attachment-img" 
            src="{{task.mediaUrl}}" 
            mode="aspectFill"
            bindtap="previewMedia"
            data-url="{{task.mediaUrl}}"
          ></image>
          <view class="attachment-hint">点击图片预览</view>
        </view>
        
        <!-- 视频附件 -->
        <view class="attachment-container" wx:if="{{task.mediaType === 'video'}}">
          <video 
            class="attachment-video" 
            src="{{task.mediaUrl}}" 
            controls
            show-play-btn="true"
            show-progress="true"
            enable-progress-gesture="true"
            object-fit="contain"
            style="width: 100%;"
          ></video>
        </view>
      </view>
    </view>
  </view>
</view>
