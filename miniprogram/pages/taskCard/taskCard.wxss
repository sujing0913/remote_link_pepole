page {
  background: #f6f7f9;
}

.container {
  padding: 24rpx;
  padding-bottom: 40rpx;
  box-sizing: border-box;
  width: 100%;
}

/* 顶部标题卡片 */
.header-card {
  background: linear-gradient(135deg, #07c160 0%, #2ad38a 60%, #70e0b6 100%);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 10rpx 26rpx rgba(7, 193, 96, 0.25);
}

.header-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.header-title {
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
}

.role-tag {
  font-size: 22rpx;
  color: #0b1220;
  background: rgba(255, 255, 255, 0.85);
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.role-tag.parent {
  background: rgba(255, 255, 255, 0.92);
}

.role-tag.child {
  background: rgba(255, 255, 255, 0.92);
}

.role-tag.guest {
  background: rgba(255, 255, 255, 0.7);
}

.header-subtitle {
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

/* 孩子选择器 */
.child-selector {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.child-picker {
  width: 100%;
}

.picker-display {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.picker-label {
  color: #fff;
  font-size: 26rpx;
}

.picker-value {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  flex: 1;
  text-align: right;
  margin: 0 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-arrow {
  color: rgba(255, 255, 255, 0.8);
  font-size: 32rpx;
  line-height: 1;
}

/* 任务列表 */
.task-list {
  width: 100%;
  box-sizing: border-box;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: #98a2b3;
  font-size: 28rpx;
}

.loading-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.loading-text {
  font-size: 26rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  background: #fff;
  border-radius: 18rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.06);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #667085;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #98a2b3;
}

/* 任务卡片 */
.task-card {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.06);
  width: 100%;
  box-sizing: border-box;
}

.task-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.task-subject {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.task-date {
  color: #98a2b3;
  font-size: 22rpx;
}

.task-content {
  margin-bottom: 16rpx;
}

.content-text {
  color: #0b1220;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.task-deadline {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #fff7e6;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.deadline-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.deadline-text {
  color: #fa8c16;
  font-size: 24rpx;
  font-weight: 500;
}

/* 附件区域 */
.task-attachment {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.attachment-container {
  width: 100%;
  box-sizing: border-box;
}

.attachment-img {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.attachment-hint {
  text-align: center;
  color: #98a2b3;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.attachment-video {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  background: #000;
}
