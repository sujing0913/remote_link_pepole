/* 容器样式 */
.container {
  padding: 0;
  background-color: #f8f8f8;
  min-height: 100vh;
}

/* 顶部标题 */
.header {
  background-color: #fff;
  padding: 30rpx 24rpx;
  margin-bottom: 0;
  border-radius: 0;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
  display: block;
}

/* 分区卡片 */
.section-card {
  background-color: transparent;
  padding: 0;
  border-radius: 0;
  margin-bottom: 0;
  box-shadow: none;
  overflow: visible;
}

/* 筛选条件模块 - 蓝色系 */
.section-card.filter-section {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  margin: 20rpx;
  border-radius: 15rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-card.filter-section .section-title {
  background: linear-gradient(135deg, #1976d2 0%, #42a5f5 100%);
  color: #fff;
}

/* 任务内容模块 - 紫色系 */
.section-card.task-section {
  background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
  margin: 20rpx;
  border-radius: 15rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-card.task-section .section-title {
  background: linear-gradient(135deg, #7b1fa2 0%, #ab47bc 100%);
  color: #fff;
}

/* 通用标题样式 */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 0;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.08);
}

/* 分区内容区域 */
.section-content {
  padding: 24rpx;
  background-color: #fff;
  width: 100%;
  box-sizing: border-box;
}

/* 筛选条件行布局 */
.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  width: 100%;
  box-sizing: border-box;
}

.filter-item {
  flex: 1;
  min-width: 0;
  width: calc(50% - 8rpx);
}

.filter-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

/* 选择器样式 */
.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f8f8f8;
  padding: 15rpx 20rpx;
  border-radius: 8rpx;
  width: 100%;
  box-sizing: border-box;
}

.picker-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-arrow {
  color: #999;
  font-size: 32rpx;
  margin-left: 8rpx;
  flex-shrink: 0;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-right: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #bbb;
  text-align: center;
  padding: 0;
  line-height: 1.5;
  width: 100%;
}

/* 任务详情卡片 */
.task-detail {
  background-color: #fafafa;
  border-radius: 8rpx;
  padding: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 任务信息 */
.task-info {
  margin-bottom: 20rpx;
  width: 100%;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  width: 100%;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #666;
  width: 160rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-value.deadline {
  color: #ff9800;
}

/* 任务详细内容 */
.task-detail-content {
  background-color: #fff;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.detail-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.detail-text {
  display: block;
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  word-wrap: break-word;
  width: 100%;
}

/* 附件区域 */
.task-attachment {
  background-color: #fff;
  border-radius: 8rpx;
  padding: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.attachment-content {
  margin-top: 15rpx;
  width: 100%;
}

.attachment-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: 8rpx;
  display: block;
}

.attachment-video {
  width: 100%;
  max-height: 400rpx;
  border-radius: 8rpx;
  display: block;
}

/* 底部提示 */
.bottom-tip {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx 30rpx;
  margin: 20rpx;
  border-radius: 15rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.4);
}

.bottom-tip text {
  font-size: 24rpx;
  color: #fff;
  line-height: 1.5;
}
