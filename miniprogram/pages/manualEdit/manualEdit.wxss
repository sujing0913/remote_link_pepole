.manual-edit-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.edit-header {
  background: white;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.edit-form {
  background: white;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.item-label {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.score-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}

.score-range {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.suggestion-textarea,
.analysis-textarea {
  width: 100%;
  min-height: 120rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background-color: #fafafa;
}

.button-group {
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 10rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-cancel {
  background: #f0f0f0;
  color: #666;
  border: 2rpx solid #ddd;
}

.btn-save {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border: none;
}

/* 输入框获得焦点时的样式 */
.score-input:focus,
.suggestion-textarea:focus,
.analysis-textarea:focus {
  border-color: #667eea;
  outline: none;
}
